{
  "manifest_version": 3,
  "name": "AutoFic",
  "version": "1.0",
  "description": "Automatiza la navegación de un lector web sin interferir con métricas.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "config.js",
        "content.js"
      ],
      "run_at": "document_start"
    }
  ]
}